<%- include("head.partial.ejs") %>

<main>
  <h1><%= title %></h1>

  <ul>
    <% genre.books.forEach(book => { %>
      <li>
        <strong><%= book.title %></strong><br />
        <em>Autor:</em> <%= book.author %><br />
        <em>Opis:</em> <%= book.description %><br />

        <% if (user) { %>
        <form action="/books/<%= book.id %>/favorite" method="POST" style="display:inline;">
          <button type="submit">Ulubione książki</button>
        </form>

        <form action="/books/<%= book.id %>/remove" method="POST" style="display:inline;">
          <button type="submit" onclick="return confirm('Czy na pewno chcesz usunąć tę książkę?')">Usuń książkę</button>
        </form>

        <form action="/books/<%= book.id %>/edit" method="GET" style="display:inline;">
          <button type="submit">Edytuj książkę</button>
        </form>
        <% } %>
      </li>
    <% }) %>
  </ul>

  <% if (user) { %>
  <div>
    <h3>Nowa książka</h3>
    <%- include("forms/new_book.ejs") %>
  </div>
  <% } else { %>
  <p><a href="/login">Zaloguj się</a>, aby dodawać książki.</p>
  <% } %>
  <a href="/books">← Powrót do gatunków</a>
</main>

<%- include("foot.partial.ejs") %>
